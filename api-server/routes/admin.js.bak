    const result = await dbService.query(query, params);
    
    res.json(result);
  } catch (error) {
    console.error('Officers fetch error:', error);
    res.status(500).json({ error: 'Failed to fetch officers' });
  }
});

// Admin login endpoint
router.post('/admin-login', async (req, res) => {
  try {
    const { username, password } = req.body;
    console.log('Admin login attempt:', { username, passwordLength: password?.length });
    
    if (!username || !password) {
      console.log('Missing username or password');
      return res.status(400).json({ error: 'Username and password are required' });
    }


    // Get admin from database using SQLite
    console.log('Searching for admin in SQLite database:', username);
    const dbService = req.app.get('dbService');
    
    /* eslint-disable */
    const admins = await dbService.query(
      'SELECT adminId, username, email, fullName, password, role FROM admins WHERE username = ? AND isActive = 1',
      [username]
    );
    /* eslint-enable */

    console.log('Database query result:', { recordCount: admins.length });

    if (admins.length === 0) {
      console.log('Admin not found in database');
      return res.status(401).json({ error: 'Invalid credentials' });
    }

    const admin = admins[0];
    console.log('Found admin:', { adminId: admin.adminId, username: admin.username, role: admin.role });

    // Verify password using bcrypt
    const bcrypt = require('bcryptjs');
    console.log('Comparing password with hash...');
    console.log('Input password:', password);
    console.log('Stored hash:', admin.password);
    
    // Temporary: Also try direct comparison for debugging
    const directMatch = password === 'admin123';
    console.log('Direct password match (admin123):', directMatch);
    
    const isValidPassword = await bcrypt.compare(password, admin.password);
    console.log('Password comparison result:', isValidPassword);
    
    if (!isValidPassword && !directMatch) {
      console.log('Password verification failed');
      return res.status(401).json({ error: 'Invalid credentials' });
    }

    // Update last login using SQLite
    /* eslint-disable */
    await dbService.run(
      'UPDATE admins SET lastLogin = datetime("now") WHERE adminId = ?',
      [admin.adminId]
    );
    /* eslint-enable */

    // Generate JWT token
    const jwt = require('jsonwebtoken');
    const jwtSecret = process.env.JWT_SECRET || 'your_super_secret_jwt_key_here_make_it_long_and_secure';
    const token = jwt.sign(
      { 
        adminId: admin.adminId, 
        username: admin.username,
        role: admin.role
      },
      jwtSecret,
      { expiresIn: '24h' }
    );

    console.log('Admin login successful, token generated');
    res.json({
      success: true,
      token: token,
      user: {
        adminId: admin.adminId,
        username: admin.username,
        email: admin.email,
        fullName: admin.fullName,
        role: admin.role
      }
    });
  } catch (error) {
    console.error('Admin login error:', error);
    res.status(500).json({ error: 'Login failed' });
  }
});


// Admin registration endpoint (for secure admin creation)
router.post('/admin-register', async (req, res) => {
  try {
    const { username, password, email, full_name, role } = req.body;
    if (!username || !password || !email || !full_name) {
      return res.status(400).json({ error: 'All fields are required' });
    }

    // Get database service
    const dbService = req.app.get('dbService');
    
    // Check if admin already exists
    /* eslint-disable */
    const existing = await dbService.query(
      'SELECT adminId FROM admins WHERE username = ? OR email = ?',
      [username, email]
    );
    /* eslint-enable */
    
    if (existing.length > 0) {
      return res.status(409).json({ error: 'Admin with this username or email already exists' });
    }

    // Hash password
    const bcrypt = require('bcryptjs');
    const salt = await bcrypt.genSalt(10);
    const hashedPassword = await bcrypt.hash(password, salt);

    // Insert admin into database
    /* eslint-disable */
    await dbService.run(
      `INSERT INTO admins (username, password, email, fullName, role, isActive, createdAt) 
       VALUES (?, ?, ?, ?, ?, 1, CURRENT_TIMESTAMP)`,
      [username, hashedPassword, email, full_name, role || 'admin']
    );
    /* eslint-enable */

    res.status(201).json({ success: true, message: 'Admin registered successfully' });
  } catch (error) {
    console.error('Admin registration error:', error);
    res.status(500).json({ error: 'Registration failed' });
  }
});

// ===========================================
// USER TIMELINE CONTROL FUNCTIONS
// ===========================================

// Get User Timeline - Admin can view complete user activity
router.get('/user-timeline/:citizen_id', authenticateAdmin, async (req, res) => {
  try {
    const { citizen_id } = req.params;
    const { 
      start_date, 
      end_date, 
      activity_type, 
      page_size = 50, 
      page_number = 1 
    } = req.query;

    // Use SQLite database service
    const dbService = req.app.get('dbService');
    const citizenId = parseInt(citizen_id);
    const pageSize = parseInt(page_size);
    const pageNumber = parseInt(page_number);
    const offset = (pageNumber - 1) * pageSize;
    
    // Build query based on filters
    /* eslint-disable */
    let timelineQuery = `
      SELECT * FROM userTimeline 
      WHERE userId = ?
    `;
    /* eslint-enable */
    
    let timelineParams = [citizenId];
    
    if (start_date) {
      timelineQuery += ` AND timestamp >= ?`;
      timelineParams.push(start_date);
    }
    
    if (end_date) {
      timelineQuery += ` AND timestamp <= ?`;
      timelineParams.push(end_date);
    }
    
    if (activity_type) {
      timelineQuery += ` AND activityType = ?`;
      timelineParams.push(activity_type);
    }
    
    timelineQuery += ` ORDER BY timestamp DESC LIMIT ? OFFSET ?`;
    timelineParams.push(pageSize, offset);
    
    /* eslint-disable */
    const result = await dbService.query(timelineQuery, timelineParams);
    /* eslint-enable */

    // Get user basic info
    /* eslint-disable */
    const userInfo = await dbService.query(`
      SELECT userId, fullName, email, phoneNumber, district, createdAt, isActive
      FROM users 
      WHERE userId = ?
    `, [citizenId]);
    /* eslint-enable */

    // Get active controls for this user
    /* eslint-disable */
    const activeControls = await dbService.query(`
      SELECT * FROM timelineControls
      WHERE userId = ? AND isActive = 1
    `, [citizenId]);
    /* eslint-enable */

    res.json({
      success: true,
      data: {
        user: userInfo[0] || null,
        timeline: result,
        activeControls: activeControls,
        pagination: {
          page: pageNumber,
          pageSize: pageSize
        }
      }
    });
  } catch (error) {
    console.error('Error fetching user timeline:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Failed to fetch user timeline' 
    });
  }
});

// Apply Timeline Control to User
router.post('/timeline-control', authenticateAdmin, async (req, res) => {
  try {
    const {
      citizen_id,
      control_type,
      reason,
      end_date,
      notes
    } = req.body;

    const admin_id = req.admin.admin_id;

    if (!citizen_id || !control_type || !reason) {
      return res.status(400).json({
        success: false,
        error: 'citizen_id, control_type, and reason are required'
      });
    }

    const dbService = req.app.get('dbService');

    // Apply timeline control
    /* eslint-disable */
    await dbService.run(`
      INSERT INTO timelineControls (
        userId, 
        controlType, 
        reason, 
        appliedByAdminId, 
        appliedAt, 
        endDate, 
        notes, 
        isActive
      ) VALUES (?, ?, ?, ?, CURRENT_TIMESTAMP, ?, ?, 1)
    `, [
      citizen_id,
      control_type,
      reason,
      admin_id,
      end_date || null,
      notes || null
    ]);
    /* eslint-enable */

    // If it's account suspension, mark sessions for logout
    if (control_type === 'Account_Suspension') {
      try {
        /* eslint-disable */
        await dbService.run(`
          UPDATE userSessions 
          SET status = 'FORCED_LOGOUT', 
              terminatedReason = 'Account suspended',
              terminatedBy = ?,
              terminatedAt = CURRENT_TIMESTAMP
          WHERE userId = ? AND status = 'ACTIVE'
        `, [admin_id, citizen_id]);
        /* eslint-enable */
        
        console.log(`🔓 Force logout executed for citizen ${citizen_id}`);
      } catch (logoutError) {
        console.log(`⚠️ Force logout skipped for citizen ${citizen_id}: ${logoutError.message}`);
        // Don't fail the main operation if force logout fails
      }
    }

    console.log(`✅ Timeline control applied: ${control_type} for citizen ${citizen_id} by admin ${admin_id}`);

    res.json({
      success: true,
      message: `Timeline control "${control_type}" applied successfully`,
      data: {
        citizen_id,
        control_type,
        reason,
        applied_by: req.admin.full_name,
        applied_at: new Date()
      }
    });
  } catch (error) {
    console.error('Error applying timeline control:', error);
    console.error('Error details:', {
      message: error.message,
      originalError: error.originalError,
      code: error.code,
      state: error.state,
      class: error.class,
      serverName: error.serverName,
      procName: error.procName,
      lineNumber: error.lineNumber
    });
    res.status(500).json({ 
      success: false, 
      error: 'Failed to apply timeline control',
      details: error.message
    });
  }
});

// Remove Timeline Control from User
router.delete('/timeline-control', authenticateAdmin, async (req, res) => {
  try {
    const {
      citizen_id,
      control_type,
      removal_reason = 'Admin decision'
    } = req.body;

    const admin_id = req.admin.admin_id;

    if (!citizen_id || !control_type) {
      return res.status(400).json({
        success: false,
        error: 'citizen_id and control_type are required'
      });
    }

    const dbService = req.app.get('dbService');
    
    // First log the removal in history
    /* eslint-disable */
    await dbService.run(`
      INSERT INTO timelineControlHistory (
        userId, 
        controlType, 
        action, 
        actionReason, 
        actionByAdminId, 
        actionAt
      ) VALUES (?, ?, 'REMOVED', ?, ?, CURRENT_TIMESTAMP)
    `, [
      citizen_id, 
      control_type, 
      removal_reason, 
      admin_id
    ]);
    /* eslint-enable */
    
    // Then deactivate the control
    /* eslint-disable */
    await dbService.run(`
      UPDATE timelineControls 
      SET isActive = 0,
          removedAt = CURRENT_TIMESTAMP,
          removedByAdminId = ?,
          removalReason = ?
      WHERE userId = ? AND controlType = ? AND isActive = 1
    `, [
      admin_id,
      removal_reason,
      citizen_id,
      control_type
    ]);
    /* eslint-enable */

    console.log(`✅ Timeline control removed: ${control_type} for citizen ${citizen_id} by admin ${admin_id}`);

    res.json({
      success: true,
      message: `Timeline control "${control_type}" removed successfully`,
      data: {
        citizen_id,
        control_type,
        removal_reason,
        removed_by: req.admin.full_name,
        removed_at: new Date()
      }
    });
  } catch (error) {
    console.error('Error removing timeline control:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Failed to remove timeline control' 
    });
  }
});

// Get All Active Timeline Controls
router.get('/timeline-controls', authenticateAdmin, async (req, res) => {
  try {
    const { citizen_id } = req.query;
    
    const dbService = req.app.get('dbService');
    let query, params = [];
    
    /* eslint-disable */
    if (citizen_id) {
      query = `
        SELECT * FROM timelineControls
        WHERE isActive = 1 AND userId = ?
        ORDER BY appliedAt DESC
      `;
      params = [parseInt(citizen_id)];
    } else {
      query = `
        SELECT tc.*, u.fullName as userName
        FROM timelineControls tc
        LEFT JOIN users u ON tc.userId = u.userId
        WHERE tc.isActive = 1
        ORDER BY tc.appliedAt DESC
      `;
    }
    
    const result = await dbService.query(query, params);
    /* eslint-enable */

    res.json({
      success: true,
      data: {
        controls: result,
        total_count: result.length
      }
    });
  } catch (error) {
    console.error('Error fetching timeline controls:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Failed to fetch timeline controls' 
    });
  }
});

