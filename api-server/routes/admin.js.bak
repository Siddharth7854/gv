      error: 'Failed to force user logout' 
    });
  }
});

// Get All Users with Timeline Status
router.get('/users-timeline-overview', authenticateAdmin, async (req, res) => {
  try {
    const { 
      page = 1, 
      limit = 20, 
      search = '', 
      status_filter = 'all',
      district_filter = 'all'
    } = req.query;

    const dbService = req.app.get('dbService');
    
    let whereClause = 'WHERE 1=1';
    let params = [];

    // Search filter
    if (search) {
      whereClause += ` AND (u.fullName LIKE ? OR u.email LIKE ? OR u.phoneNumber LIKE ?)`;
      const searchParam = `%${search}%`;
      params.push(searchParam, searchParam, searchParam);
    }

    // Status filter
    if (status_filter !== 'all') {
      if (status_filter === 'active') {
        whereClause += ` AND u.isActive = 1`;
      } else if (status_filter === 'suspended') {
        whereClause += ` AND EXISTS (
          SELECT 1 FROM timelineControls tc 
          WHERE tc.userId = u.userId 
          AND tc.controlType = 'Account_Suspension' 
          AND tc.isActive = 1
        )`;
      }
    }

    // District filter
    if (district_filter !== 'all') {
      whereClause += ` AND u.district = ?`;
      params.push(district_filter);
    }

    // Pagination
    const offset = (page - 1) * limit;
    const pageSize = parseInt(limit);
    
    /* eslint-disable */
    const usersQuery = `
      SELECT 
        u.userId,
        u.fullName,
        u.email,
        u.phoneNumber,
        u.district,
        u.createdAt,
        u.isActive,
        
        -- Count active controls
        (SELECT COUNT(*) FROM timelineControls tc 
         WHERE tc.userId = u.userId AND tc.isActive = 1) as activeControlsCount,
        
        -- Check if suspended
        (CASE WHEN EXISTS (
          SELECT 1 FROM timelineControls tc 
          WHERE tc.userId = u.userId 
          AND tc.controlType = 'Account_Suspension' 
          AND tc.isActive = 1
        ) THEN 1 ELSE 0 END) as isSuspended,
        
        -- Last activity
        (SELECT timestamp FROM userTimeline ut 
         WHERE ut.userId = u.userId 
         ORDER BY timestamp DESC LIMIT 1) as lastActivity,
         
        -- Total grievances
        (SELECT COUNT(*) FROM grievances g 
         WHERE g.userId = u.userId) as totalGrievances
         
      FROM users u
      ${whereClause}
      ORDER BY u.createdAt DESC
      LIMIT ? OFFSET ?
    `;
    
    // Add pagination params
    params.push(pageSize, offset);
    
    // Execute the main query
    const users = await dbService.query(usersQuery, params);
    
    // Execute the count query
    const countQuery = `
      SELECT COUNT(*) as total FROM users u ${whereClause}
    `;
    
    const countResult = await dbService.query(countQuery, params.slice(0, -2)); // Remove limit and offset
    /* eslint-enable */

    const query = `
      WITH UserStats AS (
        SELECT 
          c.citizen_id,
          c.full_name,
          c.email,
          c.phone,
          c.district,
          c.created_at,
          c.is_active,
          
          -- Count active controls
          (SELECT COUNT(*) FROM UserTimelineControl utc 
           WHERE utc.citizen_id = c.citizen_id AND utc.is_active = 1) as active_controls_count,
          
          -- Check if suspended
          CASE WHEN EXISTS (
            SELECT 1 FROM UserTimelineControl utc 
            WHERE utc.citizen_id = c.citizen_id 
            AND utc.control_type = 'Account_Suspension' 
            AND utc.is_active = 1
          ) THEN 1 ELSE 0 END as is_suspended,
          
          -- Last activity
          (SELECT TOP 1 created_at FROM UserActivityLogs ual 
           WHERE ual.citizen_id = c.citizen_id 
           ORDER BY created_at DESC) as last_activity,
           
          -- Total grievances
          (SELECT COUNT(*) FROM Grievances g 
           WHERE g.citizen_id = c.citizen_id) as total_grievances
           
        FROM Citizens c
        ${whereClause}
      )
      SELECT *
      FROM UserStats
      ORDER BY created_at DESC
      OFFSET @offset ROWS
      FETCH NEXT @limit ROWS ONLY;
      
      -- Get total count
      SELECT COUNT(*) as total_count
      FROM Citizens c
      ${whereClause};
    `;

    const result = await request.query(query);
    
    res.json({
      success: true,
      data: {
        users: users,
        pagination: {
          page: parseInt(page),
          limit: parseInt(limit),
          total: countResult[0].total
        }
      }
    });
  } catch (error) {
    console.error('Error fetching users timeline overview:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Failed to fetch users timeline overview' 
    });
  }
});

// Get Admin Action History
router.get('/admin-action-history', authenticateAdmin, async (req, res) => {
  try {
    const { 
      admin_id = null,
      action_type = null,
      start_date = null,
      end_date = null,
      page = 1,
      limit = 50
    } = req.query;

    const dbService = req.app.get('dbService');
    let whereClause = 'WHERE 1=1';
    let params = [];

    if (admin_id) {
      whereClause += ` AND aah.adminId = ?`;
      params.push(parseInt(admin_id));
    }

    if (action_type) {
      whereClause += ` AND aah.actionType = ?`;
      params.push(action_type);
    }

    if (start_date) {
      whereClause += ` AND aah.createdAt >= ?`;
      params.push(start_date);
    }

    if (end_date) {
      whereClause += ` AND aah.createdAt <= ?`;
      params.push(end_date);
    }

    const offset = (page - 1) * limit;
    const pageSize = parseInt(limit);

    /* eslint-disable */
    const actionsQuery = `
      SELECT 
        aah.actionId,
        aah.adminId,
        a.fullName as adminName,
        aah.targetUserId,
        u.fullName as userName,
        aah.targetGrievanceId,
        aah.actionType,
        aah.actionDescription,
        aah.previousValue,
        aah.newValue,
        aah.ipAddress,
        aah.createdAt
      FROM adminActionHistory aah
      INNER JOIN admins a ON aah.adminId = a.adminId
      LEFT JOIN users u ON aah.targetUserId = u.userId
      ${whereClause}
      ORDER BY aah.createdAt DESC
      LIMIT ? OFFSET ?
    `;
    
    // Add pagination params
    params.push(pageSize, offset);
    
    const actions = await dbService.query(actionsQuery, params);
    
    // Get total count
    const countQuery = `
      SELECT COUNT(*) as total
      FROM adminActionHistory aah
      ${whereClause}
    `;
    
    const countResult = await dbService.query(countQuery, params.slice(0, -2)); // Remove limit and offset
    /* eslint-enable */

    res.json({
      success: true,
      data: {
        actions: actions,
        pagination: {
          page: parseInt(page),
          limit: parseInt(limit),
          total: countResult[0].total
        }
      }
    });
  } catch (error) {
    console.error('Error fetching admin action history:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Failed to fetch admin action history' 
    });
  }
});

