        isActive = 0,
        terminatedAt = CURRENT_TIMESTAMP,
        terminatedBy = ?,
        terminatedReason = ?
      WHERE userId = ? AND isActive = 1
    `, [adminId, reason || 'Admin action', citizenId]);
    
    // Log this action
    await dbService.run(`
      INSERT INTO adminActionLog (
        adminId, 
        actionType, 
        targetUserId, 
        actionDetails, 
        performedAt
      ) VALUES (?, 'FORCE_LOGOUT', ?, ?, CURRENT_TIMESTAMP)
    `, [adminId, citizenId, reason || 'Admin action']);
    
    res.json({
      success: true,
      message: 'User logged out successfully'
    });
  } catch (error) {
    console.error('Error forcing user logout:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Failed to force user logout' 
    });
  }
});

// Get User Activity Summary
router.get('/user-activity-summary/:citizenId', authenticateAdmin, async (req, res) => {
  try {
    const { citizenId } = req.params;
    const { days = 30 } = req.query;
    const daysNum = parseInt(days);
    
    const dbService = req.app.get('dbService');
    
    // Calculate date for filtering (SQLite doesn't have DATEADD)
    const cutoffDate = new Date();
    cutoffDate.setDate(cutoffDate.getDate() - daysNum);
    const cutoffDateStr = cutoffDate.toISOString();
    
    // Get activity summary for the last N days
    const result = await dbService.query(`
      SELECT 
        activityType,
        COUNT(*) as count,
        MAX(createdAt) as lastActivity
      FROM userActivityLogs 
      WHERE userId = ? 
        AND createdAt >= ?
      GROUP BY activityType
      ORDER BY COUNT(*) DESC
    `, [citizenId, cutoffDateStr]);
      
    // Get total activities
    const totalResult = await dbService.query(`
      SELECT COUNT(*) as totalActivities
      FROM userActivityLogs 
      WHERE userId = ? 
        AND createdAt >= ?
    `, [citizenId, cutoffDateStr]);
    
    // Get active sessions
    const sessionsResult = await dbService.query(`
      SELECT 
        sessionId,
        loginTime,
        lastActivity,
        ipAddress,
        isActive,
        status,
        terminatedReason as logoutReason
      FROM userSessions 
      WHERE userId = ? 
      ORDER BY loginTime DESC
    `, [citizenId]);
    
    res.json({
      success: true,
      data: {
        activities: result,
        totalActivities: totalResult[0]?.totalActivities || 0,
        sessions: sessionsResult,
        period: `${days} days`
      }
    });
  } catch (error) {
    console.error('Error fetching user activity summary:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Failed to fetch user activity summary' 
    });
  }
});

// Bulk Timeline Control Actions
