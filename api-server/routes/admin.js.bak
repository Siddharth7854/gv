  try {
    const { citizenIds, controlType, reason, endDate, notes } = req.body;
    const adminId = req.admin.admin_id;
    
    if (!citizenIds || !Array.isArray(citizenIds) || !controlType || !reason) {
      return res.status(400).json({
        success: false,
        error: 'Citizen IDs array, control type, and reason are required'
      });
    }
    
    const pool = req.app.get('pool');
    const results = [];
    
    for (const citizenId of citizenIds) {
      try {
        const request = pool.request();
        
        request.input('citizen_id', citizenId);
        request.input('control_type', controlType);
        request.input('reason', reason);
        request.input('applied_by_admin_id', adminId);
        request.input('end_date', endDate || null);
        request.input('notes', notes || null);
        
        await request.execute('SP_ApplyTimelineControl');
        
        results.push({
          citizenId,
          success: true,
          message: 'Control applied successfully'
        });
      } catch (error) {
        results.push({
          citizenId,
          success: false,
          error: error.message
        });
      }
    }
    
    res.json({
      success: true,
      message: 'Bulk timeline control operation completed',
      results
    });
  } catch (error) {
    console.error('Error applying bulk timeline control:', error);
    res.status(500).json({ 
      success: false, 
      error: 'Failed to apply bulk timeline control' 
    });
  }
});

// Delete User
router.delete('/users/:userId', authenticateAdmin, async (req, res) => {
  try {
    const { userId } = req.params;
    const pool = req.app.get('pool');

    console.log(`[DELETE USER] Admin ${req.admin.admin_id} requesting to delete user ${userId}`);
    
    console.log(`[DEBUG] Looking for user with ID: ${userId}`);

    // Check if user exists
    const userCheck = await pool.request()
      .input('userId', userId)
      .query(`
        SELECT citizen_id, full_name, email 
        FROM citizens 
        WHERE citizen_id = @userId
      `);

    if (userCheck.recordset.length === 0) {
      console.log(`[DELETE USER] User ${userId} not found`);
      return res.status(404).json({
        success: false,
        error: 'User not found'
      });
    }

    const user = userCheck.recordset[0];
    console.log(`[DELETE USER] Found user: ${user.full_name} (${user.email})`);

    // Check if user has active grievances
    const grievanceCheck = await pool.request()
      .input('userId', userId)
      .query(`
        SELECT COUNT(*) as activeGrievances
        FROM grievances 
        WHERE citizen_id = @userId 
        AND status NOT IN ('Resolved', 'Closed', 'Rejected')
      `);

    const activeGrievances = grievanceCheck.recordset[0].activeGrievances;
    
    if (activeGrievances > 0) {
      console.log(`[DELETE USER] User ${userId} has ${activeGrievances} active grievances`);
      return res.status(400).json({
        success: false,
        error: `Cannot delete user with ${activeGrievances} active grievance(s). Please resolve or close them first.`
      });
    }

    // Begin transaction for safe deletion
    const transaction = pool.transaction();
    await transaction.begin();

    try {
      // Delete user's grievances first (cascade delete)
      await transaction.request()
        .input('userId', userId)
        .query(`DELETE FROM grievances WHERE citizen_id = @userId`);

      // Note: user_profiles table doesn't exist in current schema
      // If it exists in future, uncomment the line below:
      // await transaction.request()
      //   .input('userId', userId)
      //   .query(`DELETE FROM user_profiles WHERE citizen_id = @userId`);

      // Delete the user
      const deleteResult = await transaction.request()
        .input('userId', userId)
        .query(`DELETE FROM citizens WHERE citizen_id = @userId`);

      await transaction.commit();

      console.log(`[DELETE USER] Successfully deleted user ${userId} and related data`);

      res.json({
        success: true,
        message: `User ${user.full_name} deleted successfully`,
        deletedUser: {
          citizen_id: user.citizen_id,
          name: user.full_name,
          email: user.email
        }
      });

    } catch (deleteError) {
      await transaction.rollback();
      console.error(`[DELETE USER] Transaction failed:`, deleteError);
      throw deleteError;
    }

  } catch (error) {
    console.error('[DELETE USER] Error:', error);
    res.status(500).json({
      success: false,
      error: 'Failed to delete user. Please try again.',
      details: process.env.NODE_ENV === 'development' ? error.message : undefined
    });
  }
});

module.exports = router;
