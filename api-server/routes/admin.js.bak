// Get officers
router.get('/officers', authenticateAdmin, async (req, res) => {
  try {
    const dbService = req.app.get('dbService');
    const { department_id } = req.query;
    
    /* eslint-disable */
    let query = `
      SELECT 
        o.officerId as id, 
        o.fullName, 
        o.email, 
        o.phoneNumber,
        o.badgeNumber, 
        o.departmentId,
        d.name as departmentName
      FROM officers o
      LEFT JOIN departments d ON o.departmentId = d.departmentId
    `;
    /* eslint-enable */
    
    let params = [];
    if (department_id) {
      query += ` WHERE o.departmentId = ?`;
      params.push(department_id);
