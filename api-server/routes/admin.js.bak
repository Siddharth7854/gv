const express = require('express');
const router = express.Router();
const { authenticateAdmin } = require('../middleware/adminAuth');
// Use SQLite service instead of SQL Server
// const dbService = require('../config/database');

// Admin Dashboard Stats
router.get('/dashboard-stats', authenticateAdmin, async (req, res) => {
  try {
    // Use SQLite database service
    const dbService = req.app.get('dbService');
    
    // Get total grievances using SQLite
    /* eslint-disable */
    const totalResult = await dbService.query(`
      SELECT COUNT(*) as total FROM grievances
    `);
    /* eslint-enable */
    
    // Get status-wise counts using SQLite
    /* eslint-disable */
    const statusResult = await dbService.query(`
      SELECT 
        status,
        COUNT(*) as count
      FROM grievances 
      GROUP BY status
    `);
    /* eslint-enable */
    
    console.log('📊 Raw status data from database:', statusResult);
    
    // Initialize status counts
    let resolved = 0;
    let inProgress = 0;
    let pending = 0;
    let rejected = 0;

    // Map status counts using SQLite results
    statusResult.forEach(row => {
      const status = row.status;
      console.log(`Processing status: "${status}" with count: ${row.count}`);
      switch(status) {
        case 'Resolved':
          resolved = row.count;
          break;
        case 'In Progress':
          inProgress = row.count;
          break;
        case 'Submitted':
        case 'Under Review':
        case 'Pending':
          pending += row.count;
          break;
        case 'Rejected':
          rejected = row.count;
          break;
        case 'Closed':
          // Optionally treat closed as resolved or separate
          break;
        default:
          console.log(`⚠️ Unknown status found: "${status}" with count: ${row.count}`);
          pending += row.count;
      }
    });
    
    // Get total users using SQLite
    const usersResult = await dbService.query(`
      SELECT COUNT(*) as total FROM users
    `);
    
    const totalGrievances = totalResult[0]?.total || 0;
    
    console.log('📊 Dashboard Stats Debug:');
    console.log('Total Grievances:', totalGrievances);
    console.log('Status Distribution:', { resolved, inProgress, pending, rejected });
    
    res.json({
      success: true,
      data: {
        totalGrievances: totalGrievances,
        pendingGrievances: pending,
        resolvedGrievances: resolved,
        inProgressGrievances: inProgress,
        rejectedGrievances: rejected,
        totalUsers: usersResult[0]?.total || 0,
        resolutionRate: totalGrievances > 0 
          ? parseFloat(((resolved / totalGrievances) * 100).toFixed(1))
          : 0,
        // Status distribution for charts
        statusDistribution: {
          resolved,
          inProgress,
          pending,
          rejected,
          total: totalGrievances
        }
      }
    });
  } catch (error) {
    console.error('Dashboard stats error:', error);
    res.status(500).json({ 
      success: false,
      error: 'Failed to fetch dashboard stats' 
    });
  }
});

// Monthly Trends
router.get('/monthly-trends', authenticateAdmin, async (req, res) => {
  try {
    const dbService = req.app.get('dbService');
    
    // Calculate date for filtering (6 months ago)
    const sixMonthsAgo = new Date();
    sixMonthsAgo.setMonth(sixMonthsAgo.getMonth() - 6);
    const sixMonthsAgoStr = sixMonthsAgo.toISOString();
    
    // SQLite doesn't have FORMAT function, so we'll need to use strftime
    /* eslint-disable */
    const result = await dbService.query(`
      SELECT 
        strftime('%m', createdAt) as monthNum,
        CASE 
          WHEN strftime('%m', createdAt) = '01' THEN 'Jan'
          WHEN strftime('%m', createdAt) = '02' THEN 'Feb'
          WHEN strftime('%m', createdAt) = '03' THEN 'Mar'
          WHEN strftime('%m', createdAt) = '04' THEN 'Apr'
          WHEN strftime('%m', createdAt) = '05' THEN 'May'
          WHEN strftime('%m', createdAt) = '06' THEN 'Jun'
          WHEN strftime('%m', createdAt) = '07' THEN 'Jul'
          WHEN strftime('%m', createdAt) = '08' THEN 'Aug'
          WHEN strftime('%m', createdAt) = '09' THEN 'Sep'
          WHEN strftime('%m', createdAt) = '10' THEN 'Oct'
          WHEN strftime('%m', createdAt) = '11' THEN 'Nov'
          WHEN strftime('%m', createdAt) = '12' THEN 'Dec'
        END as month,
        COUNT(*) as grievances,
        SUM(CASE WHEN status = 'Resolved' THEN 1 ELSE 0 END) as resolved
      FROM grievances 
      WHERE createdAt >= ?
      GROUP BY strftime('%m', createdAt)
      ORDER BY strftime('%m', createdAt)
    `, [sixMonthsAgoStr]);
    /* eslint-enable */
    
    res.json(result);
  } catch (error) {
    console.error('Monthly trends error:', error);
    res.status(500).json({ error: 'Failed to fetch monthly trends' });
  }
});

// Category Distribution
router.get('/category-distribution', authenticateAdmin, async (req, res) => {
  try {
    const dbService = req.app.get('dbService');
    
    /* eslint-disable */
    const result = await dbService.query(`
      SELECT 
        category as name,
        COUNT(grievanceId) as value,
        CASE 
          WHEN category LIKE '%Water%' THEN '#3b82f6'
          WHEN category LIKE '%Electric%' THEN '#10b981'
          WHEN category LIKE '%Road%' OR category LIKE '%Transport%' THEN '#f59e0b'
          WHEN category LIKE '%Healthcare%' OR category LIKE '%Health%' THEN '#ef4444'
          WHEN category LIKE '%Education%' THEN '#8b5cf6'
          WHEN category LIKE '%Sanitation%' THEN '#06b6d4'
          WHEN category LIKE '%Police%' OR category LIKE '%Law%' THEN '#dc2626'
          WHEN category LIKE '%Municipal%' THEN '#059669'
          WHEN category LIKE '%Agricultural%' THEN '#65a30d'
          WHEN category LIKE '%Environmental%' THEN '#16a34a'
          ELSE '#6b7280'
        END as color
      FROM grievances
      GROUP BY category
      ORDER BY COUNT(grievanceId) DESC
    `);
    /* eslint-enable */
    
    res.json(result);
  } catch (error) {
    console.error('Category distribution error:', error);
    res.status(500).json({ error: 'Failed to fetch category distribution' });
  }
});

// All Grievances with pagination and filters
router.get('/grievances', authenticateAdmin, async (req, res) => {
  try {
    // Use SQLite database service
    const dbService = req.app.get('dbService');
    const { page = 1, limit = 10, status, priority, search } = req.query;
    const offset = (page - 1) * limit;
    
    let whereClause = 'WHERE 1=1';
    let params = [];
    
    if (status) {
      whereClause += ` AND g.status = ?`;
      params.push(status);
    }
    
    if (priority) {
      whereClause += ` AND g.priority = ?`;
      params.push(priority);
    }
    
    if (search) {
      whereClause += ` AND (g.title LIKE ? OR g.grievanceId LIKE ? OR g.category LIKE ?)`;
      const searchTerm = `%${search}%`;
      params.push(searchTerm, searchTerm, searchTerm);
    }
    
    // Add pagination params
    params.push(parseInt(limit), parseInt(offset));
    
    // Query using SQLite with proper parameterization
    /* eslint-disable */
    const grievances = await dbService.query(`
      SELECT 
        g.grievanceId as id,
        g.grievanceId as grievance_number,
        g.title,
        g.description,
        g.status,
        g.priority,
        'Normal' as urgency,
        g.createdAt as submitted_at,
        g.resolvedAt as resolved_at,
        '' as location_address,
        g.category,
        u.fullName as submittedBy,
        u.email as submitterEmail,
        u.phoneNumber as submitterPhone,
        g.assignedTo as assignedOfficer
      FROM grievances g
      LEFT JOIN users u ON g.userId = u.userId
      ${whereClause}
      ORDER BY g.createdAt DESC
      LIMIT ? OFFSET ?
    `, params);
    /* eslint-enable */
    
    // Get total count
    /* eslint-disable */
    const countResult = await dbService.query(`
      SELECT COUNT(*) as total 
      FROM grievances g
      LEFT JOIN users u ON g.userId = u.userId
      ${whereClause}
    `, params.slice(0, -2)); // Remove the limit and offset params
    /* eslint-enable */
    
    res.json({
      grievances: grievances,
      pagination: {
        page: parseInt(page),
        limit: parseInt(limit),
        total: countResult[0].total,
        totalPages: Math.ceil(countResult[0].total / limit)
      }
    });
  } catch (error) {
    console.error('Grievances fetch error:', error);
    res.status(500).json({ error: 'Failed to fetch grievances' });
  }
});

// Update Grievance Status
router.put('/grievances/:id/status', authenticateAdmin, async (req, res) => {
  try {
    // Use SQLite database service
    const dbService = req.app.get('dbService');
    const { id } = req.params;
    const { status, assignedTo, comments } = req.body;
    
    console.log(`🔄 Updating grievance ${id} status to: ${status}`);
    if (comments) {
      console.log(`💬 Admin comments: ${comments}`);
    }

    // Get current status before updating
    const currentResult = await dbService.query(`SELECT status FROM grievances WHERE grievanceId = ?`, [id]);
    if (currentResult.length === 0) {
      return res.status(404).json({ error: 'Grievance not found' });
    }
    const currentStatus = currentResult[0].status;
    
    // Update grievance
    let query = `UPDATE grievances SET status = ?, updatedAt = CURRENT_TIMESTAMP`;
    let params = [status];
    
    if (status === 'Resolved') {
      query += `, resolvedAt = CURRENT_TIMESTAMP`;
    }
    
    if (assignedTo) {
      query += `, assignedTo = ?`;
      params.push(assignedTo);
    }
    if (comments) {
      query += `, adminComments = ?`;
      params.push(comments);
    }
    query += ` WHERE grievanceId = ?`;
    params.push(id);
    
    console.log(`📝 SQL Query: ${query}`, params);
    
    await dbService.run(query, params);

    // Insert status history entry for timeline
    const adminName = req.admin ? (req.admin.fullName || req.admin.username || 'Admin') : 'Admin';
    const changeReason = comments || `Status updated to ${status} by admin`;
    
    await dbService.run(`
      INSERT INTO grievanceStatusHistory (grievanceId, previousStatus, newStatus, changedBy, changeReason, changedAt)
      VALUES (?, ?, ?, ?, ?, CURRENT_TIMESTAMP)
    `, [id, currentStatus, status, adminName, changeReason]);
    
    // Fetch the updated grievance for debug
    const updatedRow = await dbService.query(`SELECT status, resolvedAt, adminComments FROM grievances WHERE grievanceId = ?`, [id]);
    console.log(`✅ Grievance ${id} status updated successfully. Updated row:`, updatedRow[0]);

    console.log(`📊 Status history entry created: ${currentStatus} → ${status} by ${adminName}`);

    res.json({ 
      message: 'Grievance status updated successfully',
      grievanceId: id,
      newStatus: status,
      previousStatus: currentStatus,
      comments: comments || null,
      changedBy: adminName,
      debug: updatedRow[0]
    });
  } catch (error) {
    console.error('Update status error:', error);
    res.status(500).json({ error: 'Failed to update grievance status' });
  }
});

// Update Grievance Status with Images
const multer = require('multer');
const path = require('path');
const fs = require('fs');

// Configure multer for admin update images
const updateImageStorage = multer.diskStorage({
  destination: (req, file, cb) => {
    const updateDir = path.join('./uploads', 'grievance-updates');
    if (!fs.existsSync(updateDir)) {
      fs.mkdirSync(updateDir, { recursive: true });
    }
    cb(null, updateDir);
  },
  filename: (req, file, cb) => {
    const uniqueSuffix = Date.now() + '-' + Math.round(Math.random() * 1E9);
    cb(null, 'update-' + uniqueSuffix + path.extname(file.originalname));
  }
});

const updateImageUpload = multer({
  storage: updateImageStorage,
  fileFilter: (req, file, cb) => {
    if (file.mimetype.startsWith('image/')) {
      cb(null, true);
    } else {
      cb(new Error('Only image files are allowed'), false);
    }
  },
  limits: { fileSize: 5 * 1024 * 1024 } // 5MB limit
});

router.put('/grievances/:id/update-with-images', authenticateAdmin, updateImageUpload.array('images', 5), async (req, res) => {
  try {
    const dbService = req.app.get('dbService');  
    const { id } = req.params;
    const { status, comments } = req.body;
    const uploadedFiles = req.files || [];
    
    console.log(`🔄 Updating grievance ${id} with ${uploadedFiles.length} images`);
    console.log(`📝 Status: ${status}, Comments: ${comments}`);
    
    // Get current status before updating
    const currentResult = await dbService.query(`SELECT status FROM grievances WHERE grievanceId = ?`, [id]);
    if (currentResult.length === 0) {
      return res.status(404).json({ error: 'Grievance not found' });
    }
    const currentStatus = currentResult[0].status;
    
    try {
      // Update grievance status
      let query = `UPDATE grievances SET status = ?, updatedAt = CURRENT_TIMESTAMP`;
      let params = [status];
      
      if (status === 'Resolved') {
        query += `, resolvedAt = CURRENT_TIMESTAMP`;
      }
      if (comments) {
        query += `, adminComments = ?`;
        params.push(comments);
      }
      query += ` WHERE grievanceId = ?`;
      params.push(id);
      
      await dbService.run(query, params);

      // Insert status history with images
      const adminName = req.admin ? (req.admin.fullName || req.admin.username || 'Admin') : 'Admin';
      const changeReason = comments || `Status updated to ${status} by admin`;
      
      // Create image URLs for storage
      const imageUrls = uploadedFiles.map(file => `grievance-updates/${file.filename}`).join(',');
      
      await dbService.run(`
        INSERT INTO grievanceStatusHistory (grievanceId, previousStatus, newStatus, changedBy, changeReason, changedAt, imageUrls)
        VALUES (?, ?, ?, ?, ?, CURRENT_TIMESTAMP, ?)
      `, [id, currentStatus, status, adminName, changeReason, imageUrls]);

      console.log(`✅ Grievance ${id} updated with ${uploadedFiles.length} images`);

      res.json({ 
        message: 'Grievance updated successfully with images',
        grievanceId: id,
        newStatus: status,
        previousStatus: currentStatus,
        comments: comments || null,
        imagesUploaded: uploadedFiles.length,
        imageUrls: uploadedFiles.map(file => file.filename),
        changedBy: adminName
      });
    } catch (error) {
      // Clean up uploaded files on error
      uploadedFiles.forEach(file => {
        try {
          fs.unlinkSync(file.path);
        } catch (unlinkError) {
          console.error('Failed to delete file:', unlinkError);
        }
      });
      throw transactionError;
    }
  } catch (error) {
    console.error('Update with images error:', error);
    res.status(500).json({ error: 'Failed to update grievance with images' });
  }
});

// All Users with pagination
router.get('/users', authenticateAdmin, async (req, res) => {
  try {
    // Use SQLite database service
    const dbService = req.app.get('dbService');
    const { page = 1, limit = 10, role, status, search } = req.query;
    const offset = (page - 1) * limit;
    
    let whereClause = 'WHERE 1=1';
    let params = [];
    
    if (status === 'active') {
      whereClause += ` AND isActive = 1`;
    } else if (status === 'inactive') {
      whereClause += ` AND isActive = 0`;
    }
    
    if (search) {
      whereClause += ` AND (fullName LIKE ? OR email LIKE ? OR phoneNumber LIKE ?)`;
      const searchTerm = `%${search}%`;
      params.push(searchTerm, searchTerm, searchTerm);
    }
    
    // Add pagination params
    params.push(parseInt(limit), parseInt(offset));
    
    // Query using SQLite with proper parameterization
    /* eslint-disable */
    const users = await dbService.query(`
      SELECT 
        userId,
        userId as id,
        fullName,
        fullName as name,
        email,
        phoneNumber as phone,
        '' as district,
        '' as block,
        '' as ward,
        CASE WHEN isActive = 1 THEN 'active' ELSE 'inactive' END as status,
        createdAt as joinedAt,
        role,
        0 as grievancesCount
      FROM users
      ${whereClause}
      ORDER BY createdAt DESC
      LIMIT ? OFFSET ?
    `, params);
    /* eslint-enable */
    
    // Get total count for SQLite
    /* eslint-disable */
    const countResult = await dbService.query(`
      SELECT COUNT(*) as total FROM users ${whereClause}
    `, params.slice(0, -2)); // Remove limit and offset params
    /* eslint-enable */
    
    // Get grievances count per user
    const userIds = users.map(user => user.userId);
    let grievanceCounts = [];
    
    if (userIds.length > 0) {
      try {
        // Create placeholders for each userId (?, ?, ?, etc.)
        const placeholders = userIds.map(() => '?').join(',');
        
        /* eslint-disable */
        grievanceCounts = await dbService.query(`
          SELECT userId, COUNT(*) as count 
          FROM grievances 
          WHERE userId IN (${placeholders})
          GROUP BY userId
        `, userIds);
        /* eslint-enable */
        
        console.log(`Grievance counts found: ${grievanceCounts.length}`);
      } catch (countError) {
        console.error('Error getting grievance counts:', countError);
        grievanceCounts = [];
      }
      
      // Assign grievance counts to users
      users.forEach(user => {
        const userGrievances = grievanceCounts.find(g => g.userId === user.userId);
        user.grievancesCount = userGrievances ? userGrievances.count : 0;
      });
    }
    
    res.json({
      users: users,
      pagination: {
        page: parseInt(page),
        limit: parseInt(limit),
        total: countResult[0].total,
        totalPages: Math.ceil(countResult[0].total / limit)
      }
    });
  } catch (error) {
    console.error('Users fetch error:', error);
    res.status(500).json({ error: 'Failed to fetch users' });
  }
});

